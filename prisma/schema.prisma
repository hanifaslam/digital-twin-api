generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(cuid())
  name                   String
  username               String    @unique
  email                  String    @unique
  password               String
  role_id                String
  role                   Role      @relation(fields: [role_id], references: [id])
  status                 Boolean   @default(true)
  reset_password_token   String?
  reset_password_expires DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  lecturer               Lecturer?
  helper                 Helper?

  @@index([role_id])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  code        String?          @unique
  status      Boolean          @default(true)
  permissions RolePermission[]
  users       User[]
  created_at  DateTime         @default(now())
}

model Permission {
  id         String           @id @default(cuid())
  name       String           @unique // Contoh: USER_CREATE, DEVICE_CONTROL
  module_id  String
  module     Module           @relation(fields: [module_id], references: [id])
  roles      RolePermission[]
  created_at DateTime         @default(now())
}

model Module {
  id          String       @id @default(cuid())
  name        String       @unique
  code        String       @unique
  sequence    Int?         @default(0)
  permissions Permission[]
  created_at  DateTime     @default(now())
}

model RolePermission {
  role_id       String
  permission_id String
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

model Room {
  id            String         @id @default(cuid())
  name          String
  building_id   String
  building      Building       @relation(fields: [building_id], references: [id])
  floor_id      String
  floor         Floor          @relation(fields: [floor_id], references: [id])
  status        Boolean        @default(true)
  schedules     Schedule[]
  attendances   Attendance[]
  device_status DeviceStatus?
  sensor_logs   SensorLog[]
  devices       Device[]
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  @@index([building_id])
  @@index([floor_id])
}

model Building {
  id         String           @id @default(cuid())
  name       String           @unique
  code       String?          @unique
  status     Boolean          @default(true)
  rooms      Room[]
  helpers    HelperBuilding[]
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
}

model Floor {
  id         String   @id @default(cuid())
  name       String   @unique
  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  rooms      Room[]
}

model TimeSlot {
  id          String     @id @default(cuid())
  name        String     @unique
  start_time  String
  end_time    String
  schedules   Schedule[]
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  @@unique([start_time, end_time])
  @@index([start_time])
}

model Class {
  id               String       @id @default(cuid())
  name             String
  study_program_id String
  study_program    StudyProgram @relation(fields: [study_program_id], references: [id])
  schedules        Schedule[]
  status           Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@unique([study_program_id, name])
  @@index([study_program_id])
}

model Lecturer {
  id               String                @id @default(cuid())
  nip              String                @unique
  user_id          String                @unique
  user             User                  @relation(fields: [user_id], references: [id])
  study_programs   LecturerStudyProgram[]
  schedules        Schedule[]
  attendances      Attendance[]
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
}

model Helper {
  id           String           @id @default(cuid())
  phone_number String?
  user_id      String           @unique
  user         User             @relation(fields: [user_id], references: [id])
  status       Boolean          @default(true)
  buildings    HelperBuilding[]
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
}

model StudyProgram {
  id          String                @id @default(cuid())
  name        String                @unique
  code        String                @unique
  status      Boolean               @default(true)
  created_at  DateTime              @default(now())
  updated_at  DateTime              @updatedAt
  lecturers   LecturerStudyProgram[]
  courses     Course[]
  classes     Class[]
  schedules   Schedule[]
}

model Course {
  id               String       @id @default(cuid())
  code             String
  name             String
  semester         CourseSemester
  study_program_id String
  study_program    StudyProgram @relation(fields: [study_program_id], references: [id])
  schedules        Schedule[]
  status           Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@unique([study_program_id, code])
  @@unique([study_program_id, name])
  @@index([study_program_id])
  @@index([semester])
}

model LecturerStudyProgram {
  lecturer_id      String
  study_program_id String
  lecturer         Lecturer     @relation(fields: [lecturer_id], references: [id], onDelete: Cascade)
  study_program    StudyProgram @relation(fields: [study_program_id], references: [id], onDelete: Cascade)

  @@id([lecturer_id, study_program_id])
  @@index([study_program_id])
}

model HelperBuilding {
  helper_id   String
  building_id String
  helper      Helper   @relation(fields: [helper_id], references: [id], onDelete: Cascade)
  building    Building @relation(fields: [building_id], references: [id], onDelete: Cascade)

  @@id([helper_id, building_id])
  @@index([building_id])
}

model Schedule {
  id               String       @id @default(cuid())
  study_program_id String
  class_id         String
  lecturer_id String
  room_id          String
  course_id        String
  time_slot_id     String
  status           Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  study_program    StudyProgram @relation(fields: [study_program_id], references: [id])
  class            Class        @relation(fields: [class_id], references: [id])
  lecturer         Lecturer     @relation(fields: [lecturer_id], references: [id])
  room             Room         @relation(fields: [room_id], references: [id])
  course           Course       @relation(fields: [course_id], references: [id])
  time_slot        TimeSlot     @relation(fields: [time_slot_id], references: [id])

  @@unique([study_program_id, class_id, room_id, lecturer_id, course_id, time_slot_id])
  @@index([study_program_id])
  @@index([class_id])
  @@index([lecturer_id])
  @@index([room_id])
  @@index([course_id])
  @@index([time_slot_id])
}

model Attendance {
  id           String    @id @default(cuid())
  lecturer_id  String
  room_id      String
  check_in_at  DateTime  @default(now())
  check_out_at DateTime?
  status       String
  lecturer     Lecturer  @relation(fields: [lecturer_id], references: [id])
  room         Room      @relation(fields: [room_id], references: [id])

  @@index([lecturer_id])
  @@index([room_id])
  @@index([check_in_at])
}

model DeviceStatus {
  id         String   @id @default(cuid())
  room_id    String   @unique
  light      Boolean  @default(false)
  ac         Boolean  @default(false)
  updated_at DateTime @updatedAt
  room       Room     @relation(fields: [room_id], references: [id])
}

model SensorLog {
  id           String   @id @default(cuid())
  room_id      String
  voltage      Float?
  current      Float?
  power        Float?
  energy       Float?
  frequency    Float?
  power_factor Float?
  created_at   DateTime @default(now())
  room         Room     @relation(fields: [room_id], references: [id])

  @@index([room_id])
  @@index([created_at])
}

model Device {
  id         String     @id @default(cuid())
  name       String
  type       DeviceType
  room_id    String
  room       Room       @relation(fields: [room_id], references: [id])
  mqtt_topic String?
  stream_url String?
  status     Boolean    @default(true)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  @@index([room_id])
}

enum DeviceType {
  AC
  LAMP
  CCTV
}

enum CourseSemester {
  SEMESTER_1
  SEMESTER_2
  SEMESTER_3
  SEMESTER_4
  SEMESTER_5
  SEMESTER_6
  SEMESTER_7
  SEMESTER_8
}
